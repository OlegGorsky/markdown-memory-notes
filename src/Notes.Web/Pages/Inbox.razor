@page "/inbox"
@inject WebVaultSession Session

<PageTitle>Входящие — Заметки с памятью</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen />
}
else
{
    <h4>Входящие</h4>
    <p class="text-muted">Быстрый захват — мысли, у которых ещё нет своего места.</p>

    <div class="input-group mb-3">
        <input @bind="_text" class="form-control" placeholder="Запишите мысль..."
               @onkeydown="HandleKeyDown" />
        <button class="btn btn-primary" @onclick="CaptureAsync" disabled="@(string.IsNullOrWhiteSpace(_text))">
            Записать
        </button>
    </div>

    @if (_status is not null)
    {
        <div class="alert alert-success">@_status</div>
    }

    <h5 class="mt-4">Последние записи</h5>
    @if (_recentNotes.Count == 0)
    {
        <p class="text-muted">Пока нет заметок.</p>
    }
    else
    {
        @foreach (var note in _recentNotes)
        {
            <div class="card mb-2">
                <div class="card-body py-2">
                    <strong>@note.Title</strong>
                    <small class="text-muted d-block">@note.Excerpt</small>
                </div>
            </div>
        }
    }
}

@code {
    private string _text = "";
    private string? _status;
    private List<Note> _recentNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsOpen) await LoadRecentAsync();
    }

    private async Task LoadRecentAsync()
    {
        _recentNotes = (await Session.RebuildIndexAsync()).Take(20).ToList();
    }

    private async Task CaptureAsync()
    {
        if (string.IsNullOrWhiteSpace(_text)) return;
        await Session.Inbox.CaptureAsync(Session.CurrentVault!, _text);
        _status = $"Записано: {_text[..Math.Min(_text.Length, 50)]}";
        _text = "";
        await LoadRecentAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.CtrlKey && !e.ShiftKey)
        {
            await CaptureAsync();
        }
    }
}
