@page "/inbox"
@inject BrowserFileSystem FS
@inject WebVaultSession Session
@inject SyncClient Sync
@inject VaultManager VaultMgr

<PageTitle>Входящие — GorseeNote</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen VaultOpened="OnVaultOpened" />
}
else
{
    <div class="page-content animate-in">
    <h4>Входящие</h4>
    <p class="text-muted">Быстрый захват — мысли, у которых ещё нет своего места.</p>

    <div class="input-group">
        <input @bind="_text" class="glass-input" placeholder="Запишите мысль..."
               @onkeydown="HandleKeyDown" />
        <button class="glass-btn glass-btn-accent" @onclick="CaptureAsync" disabled="@(string.IsNullOrWhiteSpace(_text))">
            Записать
        </button>
    </div>

    @if (_status is not null)
    {
        <div class="glass-alert glass-alert-success">@_status</div>
    }

    <h5 class="mt-4">Последние записи</h5>
    @if (_recentNotes.Count == 0)
    {
        <p class="text-muted">Пока нет заметок.</p>
    }
    else
    {
        @foreach (var note in _recentNotes)
        {
            <div class="result-card">
                <strong>@note.Title</strong>
                <small class="d-block">@note.Excerpt</small>
            </div>
        }
    }
    </div>
}

@code {
    private string _text = "";
    private string? _status;
    private List<Note> _recentNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsOpen) await LoadRecentAsync();
    }

    private async Task OnVaultOpened()
    {
        await LoadRecentAsync();
        StateHasChanged();
    }

    private async Task LoadRecentAsync()
    {
        _recentNotes = (await Session.RebuildIndexAsync()).Take(20).ToList();
    }

    private async Task CaptureAsync()
    {
        if (string.IsNullOrWhiteSpace(_text)) return;
        var timestamp = DateTimeOffset.Now;
        var path = Session.Inbox.GetCapturePath(Session.CurrentVault!, timestamp);
        var baseHash = await TryReadContentHashAsync(path);
        path = await Session.Inbox.CaptureAsync(Session.CurrentVault!, _text, timestamp);
        var note = await Session.Notes.ReadAsync(Session.CurrentVault!, path);
        Session.UpsertIndexedNote(note);
        UpsertRecentNote(note);
        await TrySendSyncCaptureAsync(path, baseHash);
        _status = $"Записано: {_text[..Math.Min(_text.Length, 50)]}";
        _text = "";
    }

    private void UpsertRecentNote(Note note)
    {
        _recentNotes.RemoveAll(existing => existing.Id == note.Id);
        _recentNotes.Insert(0, note);
        if (_recentNotes.Count > 20)
        {
            _recentNotes.RemoveRange(20, _recentNotes.Count - 20);
        }
    }

    private async Task TrySendSyncCaptureAsync(string path, string? baseHash)
    {
        if (!await CanSendForCurrentVaultAsync())
        {
            return;
        }

        try
        {
            var content = await FS.ReadAllTextAsync(path);
            await Sync.SendFileAsync(GetRelativePath(path), content, baseHash);
        }
        catch (ArgumentException exception) when (string.Equals(exception.ParamName, "content", StringComparison.Ordinal))
        {
        }
    }

    private async Task<bool> CanSendForCurrentVaultAsync()
    {
        if (Session.CurrentVault is null)
        {
            return false;
        }

        var vault = (await VaultMgr.ListAsync()).FirstOrDefault(IsCurrentVault);
        return vault?.SyncCode is not null &&
               string.Equals(vault.SyncCode, Sync.Room, StringComparison.Ordinal);
    }

    private bool IsCurrentVault(VaultEntry vault)
    {
        if (FS.CurrentVaultId is not null &&
            string.Equals(vault.Id, FS.CurrentVaultId, StringComparison.Ordinal))
        {
            return true;
        }

        return Session.CurrentVault is not null &&
               string.Equals(vault.Path, Session.CurrentVault.RootPath, StringComparison.Ordinal);
    }

    private async Task<string?> TryReadContentHashAsync(string path)
    {
        try
        {
            if (!await FS.FileExistsAsync(path))
            {
                return null;
            }

            var content = await FS.ReadAllTextAsync(path);
            return global::Notes.Core.Sync.SyncContentHash.Compute(content);
        }
        catch
        {
            return null;
        }
    }

    private string GetRelativePath(string path)
    {
        if (Session.CurrentVault is null) return path;
        var root = Session.CurrentVault.RootPath.TrimEnd('/', '\\') + "/";
        var full = path.Replace('\\', '/');
        return full.StartsWith(root, StringComparison.Ordinal) ? full[root.Length..] : full;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.CtrlKey && !e.ShiftKey)
        {
            await CaptureAsync();
        }
    }
}
