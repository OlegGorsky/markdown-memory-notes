@using static MemoryNotes.Web.Pages.Notes

@if (Node.IsFolder)
{
    <div class="tree-folder" @onclick="() => Node.Expanded = !Node.Expanded">
        <LucideIcon Name="@(Node.Expanded ? "chevron-down" : "chevron-right")" Class="tree-arrow" />
        <LucideIcon Name="folder" Class="tree-icon" />
        <span class="tree-name">@Node.Name</span>
    </div>
    @if (Node.Expanded)
    {
        <div class="tree-children">
            @foreach (var child in Node.VisibleChildren)
            {
                <TreeNodeItem Node="child" OnSelect="OnSelect" OnDuplicate="OnDuplicate" OnDelete="OnDelete" />
            }
            @if (Node.HasHiddenChildren)
            {
                <button class="tree-more" @onclick="Node.ShowMoreChildren">
                    <LucideIcon Name="chevron-down" Class="tree-icon" />
                    <span>Ещё @Node.HiddenChildrenCount</span>
                </button>
            }
        </div>
    }
}
else if (Node.Note is not null)
{
    <div class="tree-note @(_hoverNote == Node.Note ? "hover" : "")"
         @onclick="() => OnSelect.InvokeAsync(Node.Note)"
         @onmouseenter="() => _hoverNote = Node.Note"
         @onmouseleave="() => _hoverNote = null">
        <LucideIcon Name="file-text" Class="tree-icon" />
        <span class="tree-name">@(Node.NoteTitle ?? Node.Name)</span>
        @if (_hoverNote == Node.Note)
        {
            <span class="tree-actions">
                <button class="glass-btn glass-btn-sm" title="Дублировать"
                        @onclick="() => OnDuplicate.InvokeAsync(Node.Note)" @onclick:stopPropagation="true"><LucideIcon Name="copy" /></button>
                <button class="glass-btn glass-btn-sm" title="Удалить"
                        @onclick="() => OnDelete.InvokeAsync(Node.Note)" @onclick:stopPropagation="true"><LucideIcon Name="trash-2" /></button>
            </span>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public TreeNode Node { get; set; } = null!;
    [Parameter] public EventCallback<Note> OnSelect { get; set; }
    [Parameter] public EventCallback<Note> OnDuplicate { get; set; }
    [Parameter] public EventCallback<Note> OnDelete { get; set; }

    private Note? _hoverNote;
}
