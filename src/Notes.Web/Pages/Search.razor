@page "/search"
@inject WebVaultSession Session

<PageTitle>Поиск — Заметки с памятью</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen VaultOpened="OnVaultOpened" />
}
else
{
    <div class="page-content animate-in">
    <h4>Поиск</h4>
    <div class="input-group">
        <input @bind="_query" class="glass-input glass-input-lg" placeholder="Поиск по заметкам..."
               @onkeydown="HandleKeyDown" />
        <button class="glass-btn glass-btn-accent" @onclick="DoSearchAsync">Найти</button>
    </div>

    @if (_results is not null)
    {
        <p class="text-muted">@_results.Count результатов</p>
        @foreach (var result in _results)
        {
            <div class="result-card">
                <strong>@result.Note.Title</strong>
                <span class="glass-badge glass-badge-accent ms-2">@result.Score</span>
                <small class="d-block">@result.Note.Excerpt</small>
            </div>
        }
    }
    </div>
}

@code {
    private string _query = "";
    private List<SearchResult>? _results;

    private async Task OnVaultOpened()
    {
        StateHasChanged();
    }

    private async Task DoSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        await Session.RebuildIndexAsync();
        _results = Session.Search(_query).ToList();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoSearchAsync();
    }
}
