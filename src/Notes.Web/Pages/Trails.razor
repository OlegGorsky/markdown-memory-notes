@page "/trails"
@inject WebVaultSession Session

<PageTitle>Цепочки мыслей — Заметки с памятью</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen VaultOpened="OnVaultOpened" />
}
else
{
    <div class="page-content animate-in">
    <h4>Цепочки мыслей</h4>
    <p class="text-muted">Сохранённые маршруты через ваши идеи.</p>

    <div class="input-group">
        <input @bind="_newTrailTitle" class="glass-input" placeholder="Название цепочки..." />
        <button class="glass-btn glass-btn-accent" @onclick="CreateTrailAsync"
                disabled="@(string.IsNullOrWhiteSpace(_newTrailTitle))">
            Создать цепочку
        </button>
    </div>

    @if (_trails.Count == 0)
    {
        <p class="text-muted">Пока нет цепочек. Запишите ход своих рассуждений.</p>
    }
    else
    {
        @foreach (var trail in _trails)
        {
            <div class="result-card">
                <strong>@trail.Title</strong>
                <span class="glass-badge ms-2">@trail.Items.Count эл.</span>
                <div class="mt-2">
                    @foreach (var item in trail.Items)
                    {
                        <span class="glass-badge me-1">
                            @(item.FragmentId is null ? $"заметка:{item.NoteId}" : $"фрагмент:{item.FragmentId}")
                        </span>
                    }
                </div>
            </div>
        }
    }
    </div>
}

@code {
    private string _newTrailTitle = "";
    private List<Trail> _trails = new();

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsOpen) await LoadTrailsAsync();
    }

    private async Task OnVaultOpened()
    {
        await LoadTrailsAsync();
        StateHasChanged();
    }

    private async Task LoadTrailsAsync()
    {
        _trails = (await Session.Trails.ListAsync(Session.CurrentVault!)).ToList();
    }

    private async Task CreateTrailAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTrailTitle)) return;
        await Session.Trails.CreateAsync(Session.CurrentVault!, _newTrailTitle);
        _newTrailTitle = "";
        await LoadTrailsAsync();
    }
}
