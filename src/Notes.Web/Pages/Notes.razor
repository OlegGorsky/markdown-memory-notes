@page "/"
@inject WebVaultSession Session
@inject BrowserFileSystem FS
@inject IJSRuntime JS
@inject VaultManager VaultMgr
@inject SyncClient Sync
@implements IDisposable

<PageTitle>GorseeNote</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen VaultOpened="OnVaultOpened" />
}
else
{
    <div class="app-shell">
        <div class="toolbar">
            <button class="glass-btn glass-btn-sm hamburger-btn" @onclick="() => _sidebarOpen = !_sidebarOpen">
                <LucideIcon Name="list" />
            </button>
            <span class="vault-name">@Session.CurrentVault!.RootPath</span>
            @if (_notice is not null)
            {
                <span class="sync-badge">@_notice</span>
            }
            <button class="glass-btn glass-btn-accent glass-btn-sm" @onclick="NewNoteAsync"><LucideIcon Name="plus" /> Новая</button>
        </div>

        <div class="main-grid">
            <div class="note-list @(_sidebarOpen ? "open" : "")">
                @if (_sidebarOpen)
                {
                    <button class="glass-btn glass-btn-sm sidebar-close" @onclick="() => _sidebarOpen = false">
                        <LucideIcon Name="x" />
                    </button>
                }
                <h5>Хранилища</h5>
                @foreach (var vault in _vaults)
                {
                    <div class="vault-item @(vault.Id == _activeVaultId ? "active" : "")"
                         @onclick="() => SwitchVaultAsync(vault)"
                         @onmouseenter="() => _hoverVault = vault.Id"
                         @onmouseleave="() => _hoverVault = null">
                        <LucideIcon Name="folder" Class="vault-icon" />
                        <span class="vault-label">@vault.Name</span>
                        @if (_hoverVault == vault.Id)
                        {
                            <span class="vault-actions">
                                @if (vault.SyncCode is null)
                                {
                                    <button class="glass-btn glass-btn-sm" title="Синхронизировать"
                                            @onclick="() => _syncModalVault = vault.Id" @onclick:stopPropagation="true"><LucideIcon Name="refresh-cw" /></button>
                                }
                                else
                                {
                                    <button class="glass-btn glass-btn-sm" title="Код: @vault.SyncCode"
                                            @onclick="() => _syncModalVault = vault.Id" @onclick:stopPropagation="true">
                                        <LucideIcon Name="@(IsVaultSyncConnected(vault) ? "check" : "refresh-cw")" />
                                    </button>
                                }
                                <button class="glass-btn glass-btn-sm" title="Удалить хранилище"
                                        @onclick="() => DeleteVaultAsync(vault)" @onclick:stopPropagation="true"><LucideIcon Name="x" /></button>
                            </span>
                        }
                    </div>
                    @if (vault.Id == _activeVaultId)
                    {
                        <div class="note-tree">
                            @foreach (var node in _noteTree)
                            {
                                <TreeNodeItem Node="node" OnSelect="SelectNoteAsync"
                                              OnDuplicate="DuplicateNoteAsync" OnDelete="DeleteNoteAsync" />
                            }
                        </div>
                    }
                }
                <button class="glass-btn glass-btn-sm mt-2" @onclick="() => _addMenuOpen = !_addMenuOpen"
                        style="width:100%;justify-content:center"><LucideIcon Name="plus" /> Добавить хранилище</button>
                @if (_addMenuOpen)
                {
                    <div class="add-menu animate-in">
                        <button class="toolbar-menu-item" @onclick="AddLocalVaultAsync">
                            <LucideIcon Name="folder" />
                            <span>Новое хранилище</span>
                        </button>
                        <button class="toolbar-menu-item" @onclick="() => { _addMenuOpen = false; _syncModalVault = null; _connectNewModal = true; }">
                            <LucideIcon Name="refresh-cw" />
                            <span>Подключить по коду</span>
                        </button>
                    </div>
                }
            </div>

            <div class="editor">
                @if (_selectedNote is not null)
                {
                    <div class="editor-header">
                        <input @bind="_editTitle" @bind:event="oninput" @bind:after="OnFieldChanged"
                               class="glass-input" placeholder="Заголовок" />
                        <div class="editor-toolbar-dropdown" @onfocusout="() => _toolbarOpen = false">
                            <button class="glass-btn glass-btn-sm" @onclick="() => _toolbarOpen = !_toolbarOpen"
                                    @onclick:stopPropagation="true">
                                <LucideIcon Name="plus" />
                            </button>
                            @if (_toolbarOpen)
                            {
                                <div class="toolbar-menu animate-in" @onclick:stopPropagation="true">
                                    @foreach (var item in MdFormatItems.All)
                                    {
                                        <button class="toolbar-menu-item" @onclick="() => SelectMdFormat(item.Format)">
                                            <LucideIcon Name="@item.Icon" />
                                            <span>@item.Label</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        <button class="glass-btn glass-btn-sm" @onclick="() => _previewMode = !_previewMode">
                            <LucideIcon Name="@(_previewMode ? "pencil" : "eye")" />
                            <span class="mode-label">@(_previewMode ? "С разметкой" : "Без разметки")</span>
                        </button>
                    </div>
                    @if (_previewMode)
                    {
                        <div class="md-preview animate-in">
                            @((MarkupString)RenderPreview())
                        </div>
                    }
                    else
                    {
                        <textarea @ref="_textareaRef" @bind="_editBody" @bind:event="oninput" @bind:after="OnFieldChanged"
                                  class="editor-textarea" rows="20"></textarea>
                    }
                }
                else
                {
                    <p class="text-muted text-center mt-5">Выберите заметку или создайте новую.</p>
                }
            </div>

            <div class="side-panel">
                <h6>Тихая память</h6>
                @foreach (var item in _quietMemory)
                {
                    <div class="memory-item">@item</div>
                }
            </div>
        </div>
    </div>

    @if (_sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="() => _sidebarOpen = false"></div>
    }

    @if (_syncModalVault is not null)
    {
        var vault = _vaults.FirstOrDefault(v => v.Id == _syncModalVault);
        <div class="modal-overlay" @onclick="() => _syncModalVault = null">
            <div class="modal-content glass animate-in" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Синхронизация</h4>
                    <button class="glass-btn glass-btn-sm" @onclick="() => _syncModalVault = null"><LucideIcon Name="x" /></button>
                </div>
                <div class="modal-body">
                    @if (vault?.SyncCode is not null)
                    {
                        <p class="text-muted">Код этого хранилища:</p>
                        <div class="sync-code-display">@vault.SyncCode</div>
                        <p class="text-muted mt-2">Введите этот код на другом устройстве, чтобы подключиться.</p>
                        @if (IsVaultSyncConnected(vault))
                        {
                            <span class="sync-badge connected">Подключено</span>
                        }
                        else
                        {
                            <button class="glass-btn glass-btn-accent glass-btn-sm mt-2"
                                    @onclick="() => ReconnectSyncAsync(vault)">Переподключиться</button>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Сгенерировать код для синхронизации:</p>
                        <button class="glass-btn glass-btn-accent" @onclick="() => GenerateSyncCodeForModalAsync()">
                            Сгенерировать код
                        </button>
                        <div class="mt-3">
                            <p class="text-muted">Или введите код с другого устройства:</p>
                            <div class="input-group">
                                <input @bind="_syncCodeInput" class="glass-input" placeholder="Код синхронизации" />
                                <button class="glass-btn glass-btn-accent"
                                        @onclick="ConnectSyncAsync">Подключить</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_connectNewModal)
    {
        <div class="modal-overlay" @onclick="() => _connectNewModal = false">
            <div class="modal-content glass animate-in" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Подключить хранилище</h4>
                    <button class="glass-btn glass-btn-sm" @onclick="() => _connectNewModal = false"><LucideIcon Name="x" /></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Введите код синхронизации с другого устройства:</p>
                    <div class="input-group">
                        <input @bind="_syncCodeInput" class="glass-input" placeholder="Код синхронизации" />
                        <button class="glass-btn glass-btn-accent"
                                @onclick="ConnectNewVaultAsync">Подключить</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<Note> _notes = new();
    private List<VaultEntry> _vaults = new();
    private List<TreeNode> _noteTree = new();
    private Note? _selectedNote;
    private string _editTitle = "";
    private string _editBody = "";
    private bool _previewMode;
    private bool _toolbarOpen;
    private bool _sidebarOpen;
    private bool _addMenuOpen;
    private bool _connectNewModal;
    private string? _syncModalVault;
    private string? _activeVaultId;
    private string? _hoverVault;
    private string? _notice;
    private string _syncCodeInput = "";
    private CancellationTokenSource? _autosaveCts;
    private List<string> _quietMemory = new();
    private ElementReference _textareaRef;
    private IJSObjectReference? _editorModule;
    private const string SyncOversizedNotice = "Файл слишком большой для синхронизации.";
    private const string SyncOverloadedNotice = "Синхронизация перегружена. Переподключаемся.";
    private const int InitialVisibleTreeChildren = 80;
    private const int TreeChildrenRevealStep = 80;
    private const int MaxRepairManifestEntries = 512;
    private const int MaxRepairResponseFiles = 32;

    protected override async Task OnInitializedAsync()
    {
        Sync.StateChanged += OnSyncStateChanged;
        Sync.RepairRequested = OnSyncRepairRequestedAsync;
        _editorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/text-editor.js");
        _vaults = await VaultMgr.ListAsync();
        if (Session.IsOpen && Session.CurrentVault is not null)
        {
            _activeVaultId = EnsureVaultEntry(
                FS.CurrentVaultId ?? "v_" + Guid.NewGuid().ToString("N")[..8],
                FS.CurrentVaultName ?? Path.GetFileName(Session.CurrentVault.RootPath.TrimEnd('/', '\\')),
                Session.CurrentVault.RootPath);
            await ReloadNotesAsync();
            var activeVault = _vaults.FirstOrDefault(v => v.Id == _activeVaultId);
            if (activeVault is not null)
            {
                await ConnectVaultSyncIfActiveAsync(activeVault);
            }
        }
    }

    private void OnSyncStateChanged(object? sender, EventArgs e)
    {
        UpdateSyncStatusNotice();
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateSyncStatusNotice()
    {
        if (string.Equals(Sync.Status, "overloaded", StringComparison.Ordinal))
        {
            _notice = SyncOverloadedNotice;
        }
        else if (Sync.IsConnected && string.Equals(_notice, SyncOverloadedNotice, StringComparison.Ordinal))
        {
            _notice = null;
        }
    }

    private string EnsureVaultEntry(string id, string name, string path)
    {
        var existing = _vaults.FirstOrDefault(v => v.Id == id || v.Path == path);
        if (existing is not null) return existing.Id;
        var entry = new VaultEntry(id, name, path, null);
        _vaults.Add(entry);
        _ = VaultMgr.SaveAsync(entry);
        return entry.Id;
    }

    private async Task OnVaultOpened()
    {
        _activeVaultId = EnsureVaultEntry(
            FS.CurrentVaultId ?? "v_" + Guid.NewGuid().ToString("N")[..8],
            FS.CurrentVaultName ?? Path.GetFileName(Session.CurrentVault!.RootPath.TrimEnd('/', '\\')),
            Session.CurrentVault!.RootPath);
        _vaults = await VaultMgr.ListAsync();
        await ReloadNotesAsync();
        var activeVault = _vaults.FirstOrDefault(v => v.Id == _activeVaultId);
        if (activeVault is not null)
        {
            await ConnectVaultSyncIfActiveAsync(activeVault);
        }
        StateHasChanged();
    }

    private async Task ReloadNotesAsync()
    {
        _notes = (await Session.RebuildIndexAsync()).ToList();
        _noteTree = BuildTree(_notes);
        StateHasChanged();
    }

    private List<TreeNode> BuildTree(List<Note> notes)
    {
        var priorTreeState = CaptureTreeState(_noteTree);
        var root = new List<TreeNode>();
        foreach (var note in notes.OrderBy(n => n.Title))
        {
            var rel = GetRelativePath(note.Path);
            var parts = rel.Split('/');
            var current = root;
            for (int i = 0; i < parts.Length - 1; i++)
            {
                var folder = current.FirstOrDefault(n => n.IsFolder && n.Name == parts[i]);
                if (folder is null)
                {
                    folder = new TreeNode(parts[i], true, expanded: i == 0);
                    current.Add(folder);
                }
                current = folder.Children;
            }
            current.Add(new TreeNode(parts[^1], false) { Note = note, NoteTitle = note.Title });
        }
        RestoreTreeState(root, priorTreeState);
        return root;
    }

    private static Dictionary<string, TreeNodeViewState> CaptureTreeState(IEnumerable<TreeNode> nodes)
    {
        var state = new Dictionary<string, TreeNodeViewState>(StringComparer.Ordinal);
        CaptureTreeState(nodes, parentPath: "", state);
        return state;
    }

    private static void CaptureTreeState(
        IEnumerable<TreeNode> nodes,
        string parentPath,
        Dictionary<string, TreeNodeViewState> state)
    {
        foreach (var node in nodes.Where(static node => node.IsFolder))
        {
            var nodePath = string.IsNullOrEmpty(parentPath) ? node.Name : $"{parentPath}/{node.Name}";
            state[nodePath] = new TreeNodeViewState(node.Expanded, node.VisibleChildrenCount);
            CaptureTreeState(node.Children, nodePath, state);
        }
    }

    private static void RestoreTreeState(
        IEnumerable<TreeNode> nodes,
        IReadOnlyDictionary<string, TreeNodeViewState> state)
    {
        RestoreTreeState(nodes, parentPath: "", state);
    }

    private static void RestoreTreeState(
        IEnumerable<TreeNode> nodes,
        string parentPath,
        IReadOnlyDictionary<string, TreeNodeViewState> state)
    {
        foreach (var node in nodes.Where(static node => node.IsFolder))
        {
            var nodePath = string.IsNullOrEmpty(parentPath) ? node.Name : $"{parentPath}/{node.Name}";
            if (state.TryGetValue(nodePath, out var nodeState))
            {
                node.RestoreViewState(nodeState.Expanded, nodeState.VisibleChildrenCount);
            }
            RestoreTreeState(node.Children, nodePath, state);
        }
    }

    private string RenderPreview()
    {
        if (string.IsNullOrEmpty(_editBody)) return "";
        return MarkdownPreviewRenderer.Render(_editBody);
    }

    private string GetRelativePath(string path)
    {
        if (Session.CurrentVault is null) return path;
        var root = Session.CurrentVault.RootPath.TrimEnd('/', '\\') + "/";
        var full = path.Replace('\\', '/');
        return full.StartsWith(root) ? full[root.Length..] : full;
    }

    private async Task SwitchVaultAsync(VaultEntry vault)
    {
        if (vault.Id == _activeVaultId) return;
        await AutosaveAsync();
        _selectedNote = null;
        _editTitle = "";
        _editBody = "";
        try
        {
            var handle = await FS.SwitchVaultAsync(vault.Id) ?? await FS.OpenVaultAsync(vault.Id);
            if (handle is null) return;
            await Session.OpenOrCreateAsync(handle.Path);
            _activeVaultId = vault.Id;
            _notice = null;
            await ReloadNotesAsync();
            await ConnectVaultSyncIfActiveAsync(vault);
        }
        catch
        {
            _notice = "Не удалось открыть хранилище.";
        }
    }

    private async Task AddLocalVaultAsync()
    {
        _addMenuOpen = false;
        try
        {
            var handle = await FS.OpenVaultAsync();
            if (handle is null) return;
            _autosaveCts?.Cancel();
            await AutosaveAsync();
            await Session.OpenOrCreateAsync(handle.Path);
            _activeVaultId = EnsureVaultEntry(handle.Id, handle.Name, Session.CurrentVault!.RootPath);
            _vaults = await VaultMgr.ListAsync();
            _notice = null;
            await ReloadNotesAsync();
            var activeVault = _vaults.FirstOrDefault(v => v.Id == _activeVaultId);
            if (activeVault is not null)
            {
                await ConnectVaultSyncIfActiveAsync(activeVault);
            }
        }
        catch
        {
            _notice = "Не удалось открыть хранилище.";
        }
    }

    private async Task ConnectNewVaultAsync()
    {
        if (string.IsNullOrWhiteSpace(_syncCodeInput)) return;
        var code = _syncCodeInput.Trim();
        if (!global::Notes.Core.Sync.SyncPairingCode.IsValid(code))
        {
            _notice = "Синхронизация недоступна.";
            return;
        }

        _syncCodeInput = "";
        _connectNewModal = false;

        try
        {
            var handle = await FS.OpenVaultAsync();
            if (handle is null) return;
            await Session.OpenOrCreateAsync(handle.Path);
            var vault = new VaultEntry(handle.Id, handle.Name, Session.CurrentVault!.RootPath, code);
            await VaultMgr.SaveAsync(vault);
            _vaults = await VaultMgr.ListAsync();
            _activeVaultId = vault.Id;
            await ReloadNotesAsync();

            await ConnectSyncRoomAsync(code);
        }
        catch
        {
            _notice = "Не удалось подключить хранилище.";
        }
        StateHasChanged();
    }

    private async Task DeleteVaultAsync(VaultEntry vault)
    {
        _vaults.Remove(vault);
        await VaultMgr.DeleteAsync(vault.Id);
        if (vault.Id == _activeVaultId)
        {
            _activeVaultId = _vaults.FirstOrDefault()?.Id;
            _selectedNote = null;
            if (_activeVaultId is not null)
            {
                var next = _vaults.First();
                await SwitchVaultAsync(next);
            }
        }
        StateHasChanged();
    }

    private async Task GenerateSyncCodeForModalAsync()
    {
        var vault = _vaults.FirstOrDefault(v => v.Id == _syncModalVault);
        if (vault is null) return;
        var code = global::Notes.Core.Sync.SyncPairingCode.Generate();
        var updated = vault with { SyncCode = code };
        var idx = _vaults.FindIndex(v => v.Id == vault.Id);
        _vaults[idx] = updated;
        await VaultMgr.SaveAsync(updated);
        await ConnectVaultSyncIfActiveAsync(updated);
        StateHasChanged();
    }

    private async Task ReconnectSyncAsync(VaultEntry vault)
    {
        if (vault.SyncCode is null) return;
        if (!global::Notes.Core.Sync.SyncPairingCode.IsValid(vault.SyncCode))
        {
            _notice = "Синхронизация недоступна.";
            return;
        }

        await ConnectVaultSyncIfActiveAsync(vault);
    }

    private async Task ConnectSyncAsync()
    {
        if (string.IsNullOrWhiteSpace(_syncCodeInput)) return;
        var code = _syncCodeInput.Trim();
        if (!global::Notes.Core.Sync.SyncPairingCode.IsValid(code))
        {
            _notice = "Синхронизация недоступна.";
            return;
        }

        var vault = _vaults.FirstOrDefault(v => v.Id == _syncModalVault);
        if (vault is null) return;
        var updated = vault with { SyncCode = code };
        var idx = _vaults.FindIndex(v => v.Id == vault.Id);
        _vaults[idx] = updated;
        await VaultMgr.SaveAsync(updated);
        _syncCodeInput = "";
        _syncModalVault = null;
        await ConnectVaultSyncIfActiveAsync(updated);
        StateHasChanged();
    }

    private async Task DuplicateNoteAsync(Note note)
    {
        var dup = await Session.Notes.CreateAsync(Session.CurrentVault!, note.Title + " (копия)", note.Body);
        await ReloadNotesAsync();
        await SelectNoteAsync(dup);
    }

    private async Task DeleteNoteAsync(Note note)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить «{note.Title}»?");
        if (!confirmed) return;

        var relativePath = GetRelativePath(note.Path);
        var baseHash = CanSendForActiveVault ? await TryReadContentHashAsync(note.Path) : null;
        await Session.Notes.DeleteAsync(note);
        if (CanSendForActiveVault)
        {
            await TrySendSyncChangeAsync(() => Sync.SendDeleteAsync(relativePath, baseHash));
        }

        if (_selectedNote?.Id == note.Id)
        {
            _selectedNote = null;
            _editTitle = "";
            _editBody = "";
        }

        RemoveLoadedNote(note.Id);
    }

    private void OnFieldChanged()
    {
        ScheduleAutosave();
    }

    private void ScheduleAutosave()
    {
        _autosaveCts?.Cancel();
        _autosaveCts = new CancellationTokenSource();
        var token = _autosaveCts.Token;
        _ = Task.Run(async () =>
        {
            await Task.Delay(800, token);
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(AutosaveAsync);
            }
        }, token);
    }

    private async Task AutosaveAsync()
    {
        if (_selectedNote is null) return;
        var baseHash = CanSendForActiveVault ? await TryReadContentHashAsync(_selectedNote.Path) : null;
        var updated = _selectedNote with { Title = _editTitle, Body = _editBody };
        _selectedNote = await Session.Notes.SaveAsync(updated);
        if (CanSendForActiveVault)
        {
            var relativePath = GetRelativePath(_selectedNote.Path);
            var content = await FS.ReadAllTextAsync(_selectedNote.Path);
            await TrySendSyncChangeAsync(() => Sync.SendFileAsync(relativePath, content, baseHash));
        }
        UpsertLoadedNote(_selectedNote);
    }

    private void UpsertLoadedNote(Note note)
    {
        var index = _notes.FindIndex(existing => existing.Id == note.Id);
        if (index >= 0)
        {
            _notes[index] = note;
        }
        else
        {
            _notes.Add(note);
        }

        Session.UpsertIndexedNote(note);
        _noteTree = BuildTree(_notes);
        RefreshQuietMemory(note);
        StateHasChanged();
    }

    private void RemoveLoadedNote(string noteId)
    {
        RemoveLoadedNoteCore(noteId);
        StateHasChanged();
    }

    private void RemoveLoadedNoteCore(string noteId)
    {
        _notes.RemoveAll(note => note.Id == noteId);
        Session.RemoveIndexedNote(noteId);
        _noteTree = BuildTree(_notes);
        if (_selectedNote is null)
        {
            _quietMemory.Clear();
        }
    }

    private async Task TrySendSyncChangeAsync(Func<Task> sendAsync)
    {
        ArgumentNullException.ThrowIfNull(sendAsync);

        try
        {
            await sendAsync();
            if (string.Equals(_notice, SyncOversizedNotice, StringComparison.Ordinal))
            {
                _notice = null;
            }
        }
        catch (ArgumentException exception) when (string.Equals(exception.ParamName, "content", StringComparison.Ordinal))
        {
            _notice = SyncOversizedNotice;
        }
    }

    private async Task ConnectSyncRoomAsync(string code)
    {
        await Sync.ConnectAsync(
            code,
            async (path, content, baseHash) =>
            {
                var result = content is null
                    ? await Session.SyncChanges.ApplyDeleteAsync(path, baseHash)
                    : await Session.SyncChanges.ApplyFileAsync(path, content, baseHash);

                if (result is global::Notes.Core.Sync.SyncApplyResult.ConflictSaved or
                    global::Notes.Core.Sync.SyncApplyResult.ConflictSkipped)
                {
                    _notice = "Есть конфликт синхронизации.";
                }
                await InvokeAsync(ReloadNotesAsync);
            },
            OnRepairRequestReceivedAsync);
    }

    private async Task ConnectVaultSyncIfActiveAsync(VaultEntry vault)
    {
        if (vault.Id != _activeVaultId)
        {
            return;
        }

        if (vault.SyncCode is null ||
            !global::Notes.Core.Sync.SyncPairingCode.IsValid(vault.SyncCode))
        {
            await DisconnectSyncRoomAsync();
            return;
        }

        try
        {
            await ConnectSyncRoomAsync(vault.SyncCode);
        }
        catch
        {
            _notice = "Синхронизация недоступна.";
        }
    }

    private async Task DisconnectSyncRoomAsync()
    {
        if (Sync.Room is null && !Sync.IsConnected)
        {
            return;
        }

        try
        {
            await Sync.DisconnectAsync();
        }
        catch
        {
            _notice = "Синхронизация недоступна.";
        }
    }

    private async Task OnSyncRepairRequestedAsync()
    {
        if (!CanSendForActiveVault || Session.CurrentVault is null)
        {
            return;
        }

        try
        {
            var manifest = await Session.SyncRepair.BuildManifestAsync(
                Session.CurrentVault,
                Math.Min(MaxRepairManifestEntries, global::Notes.Core.Sync.SyncRepairRequestMessage.MaxEntries));
            await Sync.SendRepairRequestAsync(manifest);
        }
        catch
        {
            _notice = "Синхронизация недоступна.";
        }
    }

    private async Task OnRepairRequestReceivedAsync(global::Notes.Core.Sync.SyncRepairRequest request)
    {
        if (!CanSendForActiveVault || Session.CurrentVault is null)
        {
            return;
        }

        try
        {
            var changes = await Session.SyncRepair.FindChangesForAsync(
                Session.CurrentVault,
                request,
                MaxRepairResponseFiles);
            foreach (var change in changes)
            {
                await TrySendSyncChangeAsync(async () =>
                    await Sync.TrySendRepairFileAsync(change.Path, change.Content, change.BaseHash));
            }
        }
        catch
        {
            _notice = "Синхронизация недоступна.";
        }
    }

    private async Task<string?> TryReadContentHashAsync(string path)
    {
        try
        {
            if (!await FS.FileExistsAsync(path))
            {
                return null;
            }

            var content = await FS.ReadAllTextAsync(path);
            return global::Notes.Core.Sync.SyncContentHash.Compute(content);
        }
        catch
        {
            return null;
        }
    }

    private bool CanSendForActiveVault
    {
        get
        {
            var vault = _vaults.FirstOrDefault(v => v.Id == _activeVaultId);
            return vault is not null && IsVaultSyncRoom(vault);
        }
    }

    private bool IsVaultSyncConnected(VaultEntry vault)
    {
        return Sync.IsConnected && IsVaultSyncRoom(vault);
    }

    private bool IsVaultSyncRoom(VaultEntry vault)
    {
        return vault.SyncCode is not null &&
               string.Equals(vault.SyncCode, Sync.Room, StringComparison.Ordinal);
    }

    private async Task SelectNoteAsync(Note note)
    {
        if (_selectedNote?.Id != note.Id)
        {
            _autosaveCts?.Cancel();
            await AutosaveAsync();
        }
        _selectedNote = note;
        _editTitle = note.Title;
        _editBody = note.Body;
        RefreshQuietMemory(note);
        StateHasChanged();
    }

    private async Task NewNoteAsync()
    {
        _autosaveCts?.Cancel();
        await AutosaveAsync();
        var note = await Session.Notes.CreateAsync(Session.CurrentVault!, "Без названия", "Начните писать...");
        await ReloadNotesAsync();
        await SelectNoteAsync(note);
    }

    private void RefreshQuietMemory(Note note)
    {
        _quietMemory = Session.QuietMemory
            .Suggest(new MemoryQuery(note, note.Body, 5))
            .Select(c => c.Note.Title)
            .ToList();
    }

    private async Task SelectMdFormat(MdFormat fmt)
    {
        _toolbarOpen = false;
        await InsertMdFormat(fmt);
    }

    private enum MdFormat { Bold, Italic, Heading, List, Code, Link, Quote, Table, Image, Divider, Checklist }

    private sealed record MdFormatItem(MdFormat Format, string Icon, string Label);

    private static class MdFormatItems
    {
        public static readonly MdFormatItem[] All = [
            new(MdFormat.Bold, "bold", "Жирный"),
            new(MdFormat.Italic, "italic", "Курсив"),
            new(MdFormat.Heading, "heading", "Заголовок"),
            new(MdFormat.List, "list", "Список"),
            new(MdFormat.Code, "code", "Код"),
            new(MdFormat.Link, "link", "Ссылка"),
            new(MdFormat.Quote, "quote", "Цитата"),
            new(MdFormat.Table, "table", "Таблица"),
            new(MdFormat.Image, "image", "Картинка"),
            new(MdFormat.Divider, "minus", "Разделитель"),
            new(MdFormat.Checklist, "list-checks", "Чеклист"),
        ];
    }

    private async Task InsertMdFormat(MdFormat fmt)
    {
        var (before, after, placeholder) = fmt switch
        {
            MdFormat.Bold => ("**", "**", "текст"),
            MdFormat.Italic => ("*", "*", "текст"),
            MdFormat.Heading => ("## ", "", "Заголовок"),
            MdFormat.List => ("- ", "", "элемент"),
            MdFormat.Code => ("```\n", "\n```", "код"),
            MdFormat.Link => ("[", "](url)", "текст"),
            MdFormat.Quote => ("> ", "", "цитата"),
            MdFormat.Table => ("| Заголовок | Заголовок |\n|---|---|\n| ", " |", "ячейка"),
            MdFormat.Image => ("![", "](url)", "описание"),
            MdFormat.Divider => ("\n---\n", "", ""),
            MdFormat.Checklist => ("- [ ] ", "", "задача"),
            _ => ("", "", "")
        };
        await InsertFormattingAsync(before, after, placeholder);
    }

    private async Task InsertFormattingAsync(string before, string after, string placeholder)
    {
        if (_editorModule is not null)
        {
            await _editorModule.InvokeVoidAsync("insertFormatting", _textareaRef, before, after, placeholder);
        }
    }

    public void Dispose()
    {
        if (Sync is not null)
        {
            Sync.StateChanged -= OnSyncStateChanged;
            if (Sync.RepairRequested == OnSyncRepairRequestedAsync)
            {
                Sync.RepairRequested = null;
            }
        }

        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
    }

    public sealed class TreeNode
    {
        public string Name { get; }
        public bool IsFolder { get; }
        public List<TreeNode> Children { get; } = new();
        public Note? Note { get; set; }
        public string? NoteTitle { get; set; }
        public bool Expanded { get; set; } = true;
        public int VisibleChildrenCount { get; private set; } = InitialVisibleTreeChildren;
        public IEnumerable<TreeNode> VisibleChildren => Children.Take(VisibleChildrenCount);
        public bool HasHiddenChildren => VisibleChildrenCount < Children.Count;
        public int HiddenChildrenCount => Math.Max(0, Children.Count - VisibleChildrenCount);

        public TreeNode(string name, bool isFolder, bool expanded = true)
        {
            Name = name;
            IsFolder = isFolder;
            Expanded = expanded;
        }

        public void ShowMoreChildren()
        {
            VisibleChildrenCount = Math.Min(Children.Count, VisibleChildrenCount + TreeChildrenRevealStep);
        }

        public void RestoreViewState(bool expanded, int visibleChildrenCount)
        {
            Expanded = expanded;
            VisibleChildrenCount = Math.Min(
                Children.Count,
                Math.Max(InitialVisibleTreeChildren, visibleChildrenCount));
        }
    }

    private readonly record struct TreeNodeViewState(bool Expanded, int VisibleChildrenCount);
}
