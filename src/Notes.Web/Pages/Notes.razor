@page "/"
@inject WebVaultSession Session
@inject BrowserFileSystem FS
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>GorseeNote</PageTitle>

@if (!Session.IsOpen)
{
    <VaultOpen VaultOpened="OnVaultOpened" />
}
else
{
    <div class="app-shell">
        <div class="toolbar">
            <span class="vault-name">@Session.CurrentVault!.RootPath</span>
            <button class="glass-btn glass-btn-accent glass-btn-sm" @onclick="NewNoteAsync">+ Новая</button>
        </div>

        <div class="main-grid">
            <div class="note-list">
                <h5>Заметки (@_notes.Count)</h5>
                @foreach (var note in _notes)
                {
                    <div class="note-card @(note == _selectedNote ? "selected" : "")"
                         @onclick="() => SelectNoteAsync(note)">
                        <div class="note-title">@note.Title</div>
                        <div class="note-excerpt">@note.Excerpt</div>
                    </div>
                }
            </div>

            <div class="editor">
                @if (_selectedNote is not null)
                {
                    <div class="editor-header">
                        <input @bind="_editTitle" @bind:event="oninput" @bind:after="OnFieldChanged"
                               class="glass-input" placeholder="Заголовок" />
                        <button class="glass-btn glass-btn-sm" @onclick="() => _previewMode = !_previewMode">
                            @(_previewMode ? "✎ Ред." : "◉ Превью")
                        </button>
                    </div>
                    @if (_previewMode)
                    {
                        <div class="md-preview animate-in">
                            @((MarkupString)Markdown.ToHtml(_editBody))
                        </div>
                    }
                    else
                    {
                        <div class="editor-toolbar">
                            <button class="glass-btn glass-btn-sm" title="Жирный" @onclick="() => InsertMdFormat(MdFormat.Bold)"><b>B</b></button>
                            <button class="glass-btn glass-btn-sm" title="Курсив" @onclick="() => InsertMdFormat(MdFormat.Italic)"><i>I</i></button>
                            <button class="glass-btn glass-btn-sm" title="Заголовок" @onclick="() => InsertMdFormat(MdFormat.Heading)">H</button>
                            <button class="glass-btn glass-btn-sm" title="Список" @onclick="() => InsertMdFormat(MdFormat.List)">&equiv;</button>
                            <button class="glass-btn glass-btn-sm" title="Код" @onclick="() => InsertMdFormat(MdFormat.Code)">&lt;/&gt;</button>
                            <button class="glass-btn glass-btn-sm" title="Ссылка" @onclick="() => InsertMdFormat(MdFormat.Link)">🔗</button>
                            <button class="glass-btn glass-btn-sm" title="Цитата" @onclick="() => InsertMdFormat(MdFormat.Quote)">❝</button>
                            <button class="glass-btn glass-btn-sm" title="Таблица" @onclick="() => InsertMdFormat(MdFormat.Table)">⊞</button>
                            <button class="glass-btn glass-btn-sm" title="Картинка" @onclick="() => InsertMdFormat(MdFormat.Image)">🖼</button>
                            <button class="glass-btn glass-btn-sm" title="Разделитель" @onclick="() => InsertMdFormat(MdFormat.Divider)">—</button>
                            <button class="glass-btn glass-btn-sm" title="Чеклист" @onclick="() => InsertMdFormat(MdFormat.Checklist)">☐</button>
                        </div>
                        <textarea @ref="_textareaRef" @bind="_editBody" @bind:event="oninput" @bind:after="OnFieldChanged"
                                  class="editor-textarea" rows="20"></textarea>
                    }
                }
                else
                {
                    <p class="text-muted text-center mt-5">Выберите заметку или создайте новую.</p>
                }
            </div>

            <div class="side-panel">
                <h6>Тихая память</h6>
                @foreach (var item in _quietMemory)
                {
                    <div class="memory-item">@item</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Note> _notes = new();
    private Note? _selectedNote;
    private string _editTitle = "";
    private string _editBody = "";
    private bool _previewMode;
    private CancellationTokenSource? _autosaveCts;
    private List<string> _quietMemory = new();
    private ElementReference _textareaRef;
    private IJSObjectReference? _editorModule;

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsOpen) await ReloadNotesAsync();
        _editorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/text-editor.js");
    }

    private async Task OnVaultOpened()
    {
        await ReloadNotesAsync();
        StateHasChanged();
    }

    private async Task ReloadNotesAsync()
    {
        _notes = (await Session.RebuildIndexAsync()).ToList();
        StateHasChanged();
    }

    private void OnFieldChanged()
    {
        ScheduleAutosave();
    }

    private void ScheduleAutosave()
    {
        _autosaveCts?.Cancel();
        _autosaveCts = new CancellationTokenSource();
        var token = _autosaveCts.Token;
        _ = Task.Run(async () =>
        {
            await Task.Delay(800, token);
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(AutosaveAsync);
            }
        }, token);
    }

    private async Task AutosaveAsync()
    {
        if (_selectedNote is null) return;
        var updated = _selectedNote with { Title = _editTitle, Body = _editBody };
        _selectedNote = await Session.Notes.SaveAsync(updated);
        await ReloadNotesAsync();
    }

    private async Task SelectNoteAsync(Note note)
    {
        if (_selectedNote?.Id != note.Id)
        {
            _autosaveCts?.Cancel();
            await AutosaveAsync();
        }
        _selectedNote = note;
        _editTitle = note.Title;
        _editBody = note.Body;
        RefreshQuietMemory(note);
        StateHasChanged();
    }

    private async Task NewNoteAsync()
    {
        _autosaveCts?.Cancel();
        await AutosaveAsync();
        var note = await Session.Notes.CreateAsync(Session.CurrentVault!, "Без названия", "Начните писать...");
        await ReloadNotesAsync();
        await SelectNoteAsync(note);
    }

    private void RefreshQuietMemory(Note note)
    {
        _quietMemory = Session.QuietMemory
            .Suggest(new MemoryQuery(note, note.Body, 5))
            .Select(c => c.Note.Title)
            .ToList();
    }

    private enum MdFormat { Bold, Italic, Heading, List, Code, Link, Quote, Table, Image, Divider, Checklist }

    private async Task InsertMdFormat(MdFormat fmt)
    {
        var (before, after, placeholder) = fmt switch
        {
            MdFormat.Bold => ("**", "**", "текст"),
            MdFormat.Italic => ("*", "*", "текст"),
            MdFormat.Heading => ("## ", "", "Заголовок"),
            MdFormat.List => ("- ", "", "элемент"),
            MdFormat.Code => ("```\n", "\n```", "код"),
            MdFormat.Link => ("[", "](url)", "текст"),
            MdFormat.Quote => ("> ", "", "цитата"),
            MdFormat.Table => ("| Заголовок | Заголовок |\n|---|---|\n| ", " |", "ячейка"),
            MdFormat.Image => ("![", "](url)", "описание"),
            MdFormat.Divider => ("\n---\n", "", ""),
            MdFormat.Checklist => ("- [ ] ", "", "задача"),
            _ => ("", "", "")
        };
        await InsertFormattingAsync(before, after, placeholder);
    }

    private async Task InsertFormattingAsync(string before, string after, string placeholder)
    {
        if (_editorModule is not null)
        {
            await _editorModule.InvokeVoidAsync("insertFormatting", _textareaRef, before, after, placeholder);
        }
    }

    public void Dispose()
    {
        _autosaveCts?.Cancel();
        _autosaveCts?.Dispose();
    }
}
