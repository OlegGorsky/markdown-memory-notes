@inject BrowserFileSystem FS
@inject WebVaultSession Session
@inject NavigationManager Nav

<div class="vault-open">
    <h1>Markdown Memory Notes</h1>
    <p class="lead">Notes that remember how you think.</p>
    <p class="text-muted">Заметки, которые помнят ход мысли.</p>

    <button class="btn btn-primary btn-lg" @onclick="OpenVault">
        Open vault folder
    </button>

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <p class="mt-3 text-muted small">
        Your notes stay on your device. The app reads and writes
        Markdown files directly in the folder you choose.
    </p>
</div>

@code {
    private string? _error;

    private async Task OpenVault()
    {
        _error = null;
        try
        {
            var name = await FS.OpenVaultAsync();
            if (name is null) return;
            Session.OpenOrCreate(name);
            Nav.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
