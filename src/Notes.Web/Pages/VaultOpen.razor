@inject BrowserFileSystem FS
@inject WebVaultSession Session
@inject NavigationManager Nav

<div class="vault-open">
    <h1>Заметки с памятью</h1>
    <p class="lead">Заметки, которые помнят ход мысли.</p>

    <button class="btn btn-primary btn-lg" @onclick="OpenVault">
        Открыть папку хранилища
    </button>

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <p class="mt-3 text-muted small">
        Ваши заметки остаются на устройстве. Приложение читает и пишет
        Markdown-файлы напрямую в выбранной папке.
    </p>
</div>

@code {
    private string? _error;

    private async Task OpenVault()
    {
        _error = null;
        try
        {
            var name = await FS.OpenVaultAsync();
            if (name is null) return;
            Session.OpenOrCreate(name);
            Nav.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
