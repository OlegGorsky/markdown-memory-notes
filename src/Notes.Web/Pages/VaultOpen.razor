@inject BrowserFileSystem FS
@inject WebVaultSession Session
@inject NavigationManager Nav

<div class="vault-open">
    <h1>GorseeNote</h1>
    <p class="lead">Заметки, которые помнят ход мысли.</p>

    @if (_restoring)
    {
        <p class="text-muted">Восстанавливаю...</p>
    }
    else
    {
        <button class="glass-btn glass-btn-accent glass-btn-lg" @onclick="OpenVault">
            Открыть папку
        </button>
    }

    @if (_error is not null)
    {
        <div class="glass-alert glass-alert-danger mt-3">@_error</div>
    }
</div>

@code {
    [Parameter]
    public EventCallback VaultOpened { get; set; }

    private string? _error;
    private bool _restoring = true;

    protected override async Task OnInitializedAsync()
    {
        await TryRestoreAsync();
    }

    private async Task TryRestoreAsync()
    {
        try
        {
            var vault = await FS.TryRestoreVaultAsync();
            if (vault is not null)
            {
                await Session.OpenOrCreateAsync(vault.Path);
                await VaultOpened.InvokeAsync();
            }
        }
        catch
        {
            // Will show the open button
        }
        finally
        {
            _restoring = false;
        }
    }

    private async Task OpenVault()
    {
        _error = null;
        try
        {
            var vault = await FS.OpenVaultAsync();
            if (vault is null) return;
            await Session.OpenOrCreateAsync(vault.Path);
            await VaultOpened.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
