@inject BrowserFileSystem FS
@inject WebVaultSession Session
@inject NavigationManager Nav

<div class="vault-open">
    <h1>Заметки с памятью</h1>
    <p class="lead">Заметки, которые помнят ход мысли.</p>

    @if (_restoring)
    {
        <p class="text-muted">Восстанавливаю хранилище...</p>
    }
    else
    {
        <button class="btn btn-primary btn-lg" @onclick="OpenVault">
            Открыть папку хранилища
        </button>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <p class="mt-3 text-muted small">
        Ваши заметки остаются на устройстве. Приложение читает и пишет
        Markdown-файлы напрямую в выбранной папке.
    </p>
</div>

@code {
    [Parameter]
    public EventCallback VaultOpened { get; set; }

    private string? _error;
    private bool _restoring = true;

    protected override async Task OnInitializedAsync()
    {
        await TryRestoreAsync();
    }

    private async Task TryRestoreAsync()
    {
        try
        {
            var name = await FS.TryRestoreVaultAsync();
            if (name is not null)
            {
                await Session.OpenOrCreateAsync(name);
                await VaultOpened.InvokeAsync();
            }
        }
        catch
        {
            // Will show the open button
        }
        finally
        {
            _restoring = false;
        }
    }

    private async Task OpenVault()
    {
        _error = null;
        try
        {
            var name = await FS.OpenVaultAsync();
            if (name is null) return;
            await Session.OpenOrCreateAsync(name);
            await VaultOpened.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
