# syntax=docker/dockerfile:1.7

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY Directory.Build.props MarkdownMemoryNotes.sln ./
COPY src/Notes.Core/Notes.Core.csproj src/Notes.Core/
COPY src/Notes.Web/Notes.Web.csproj src/Notes.Web/
RUN dotnet restore src/Notes.Web/Notes.Web.csproj

COPY src/Notes.Core/ src/Notes.Core/
COPY src/Notes.Web/ src/Notes.Web/
RUN dotnet publish src/Notes.Web/Notes.Web.csproj \
	-c Release \
	-o /app/publish \
	--no-restore

FROM caddy:2-alpine

ENV XDG_CONFIG_HOME=/config \
	XDG_DATA_HOME=/data

COPY deploy/note/Caddyfile.web /etc/caddy/Caddyfile
COPY --from=build --chown=65534:65534 /app/publish/wwwroot/ /srv/www/

RUN cp /usr/bin/caddy /tmp/caddy \
	&& chmod 0755 /tmp/caddy \
	&& mv /tmp/caddy /usr/bin/caddy \
	&& mkdir -p /data /config \
	&& chown -R 65534:65534 /data /config /srv/www

USER 65534:65534
EXPOSE 8080
